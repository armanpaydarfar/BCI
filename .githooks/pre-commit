#!/usr/bin/env bash
# Harmony: soft reminder to update CHANGELOG.md / README when editing core surfaces.
# Enable once per clone: git config core.hooksPath .githooks
set -euo pipefail

mapfile -t staged < <(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)
(( ${#staged[@]} == 0 )) && exit 0

changelog_staged=false
readme_staged=false
for f in "${staged[@]}"; do
  [[ "$f" == "CHANGELOG.md" ]] && changelog_staged=true
  [[ "$f" == "README.md" ]] && readme_staged=true
done

need_log=false
need_readme_hint=false
for f in "${staged[@]}"; do
  case "$f" in
    config.py|control_panel.py|environment.yml|\
Utils/runtime_common.py|Utils/EEGStreamState.py|Utils/networking.py|Utils/experiment_utils.py)
      need_log=true
      ;;
    ExperimentDriver*.py|Generate_Riemannian_adaptive.py|\
generate_xgboost*.py|explore_dataset_library.py)
      need_log=true
      ;;
    Utils/xgb_feature_pipeline.py|Utils/visualization.py)
      need_log=true
      ;;
  esac
  case "$f" in
    environment.yml|control_panel.py|ExperimentDriver*.py)
      need_readme_hint=true
      ;;
  esac
done

warn() { printf '\033[1;33m%s\033[0m %s\n' "hint:" "$1" >&2; }

if [[ "$need_log" == true && "$changelog_staged" != true ]]; then
  warn "You are committing changes under config/runtime/train entrypoints. Consider adding a brief bullet under [Unreleased] in CHANGELOG.md."
fi

if [[ "$need_readme_hint" == true && "$readme_staged" != true ]]; then
  warn "Setup or entry-point behavior may have changed. If users need new steps, update README.md."
fi

# Hard gate: run the fast pytest suite (Harmony_Test_Suite_Plan.md §5.3).
# The standalone script is kept under tools/ so it can be invoked manually
# too. Failure here aborts the commit.
repo_root="$(git rev-parse --show-toplevel)"
pytest_hook="${repo_root}/tools/pre-commit-pytest.sh"
if [[ -x "$pytest_hook" ]]; then
  "$pytest_hook" || exit $?
fi

exit 0
